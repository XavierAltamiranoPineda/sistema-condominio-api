# ===================================================
# SISTEMA CONDOMINIO API - Variables de Entorno
# ===================================================
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env al repositorio

# ===== BASE DE DATOS (Supabase PostgreSQL) =====
DB_URL=jdbc:postgresql://db.<tu-proyecto>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=tu_password_supabase

# ===== JWT =====
# Genera una clave aleatoria de al menos 256 bits
# Comando: openssl rand -base64 64
JWT_SECRET=tu_clave_secreta_de_al_menos_256_bits_aqui_generada_con_openssl
# Expiración en milisegundos: 86400000 = 24 horas
JWT_EXPIRATION=86400000

# ===== CORS =====
# Separar múltiples orígenes con coma
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ===== SERVER =====
SERVER_PORT=8080
